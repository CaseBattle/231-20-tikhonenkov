<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
    bootstrap="tests/bootstrap.php"
    colors="true"
    cacheDirectory=".phpunit.cache"
    displayDetailsOnIncompleteTests="true"
    displayDetailsOnSkippedTests="true"
    executionOrder="random"
    beStrictAboutTestsThatDoNotTestAnything="true"
>
    <testsuites>
        <testsuite name="Authentication Forms Test Suite">
            <directory>tests</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory suffix=".php">src</directory>
        </include>
    </source>

    <logging>
        <junit outputFile="tests/logs/junit.xml"/>
        <testdoxHtml outputFile="tests/logs/testdox.html"/>
        <testdoxText outputFile="tests/logs/testdox.txt"/>
    </logging>

    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Подключение к тестовой БД.
             По умолчанию настроено на локальный MySQL с пользователем root БЕЗ пароля,
             как это обычно бывает в XAMPP/OpenServer на учебных ПК. -->
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="3306"/>
        <env name="DB_NAME" value="auth_project_test"/>
        <env name="DB_USER" value="root"/>
        <env name="DB_PASSWORD" value="123123"/>
        <env name="TEST_MAX_DURATION" value="2.0"/>
    </php>
</phpunit>