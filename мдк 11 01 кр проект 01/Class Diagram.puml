@startuml
title База данных аренды жилья

class User {
  - id: BIGINT
  - email: VARCHAR
  - name: VARCHAR
  - phone: VARCHAR
  - type: ENUM
}

class Property {
  - id: BIGINT
  - landlord_id: BIGINT
  - title: VARCHAR
  - address: TEXT
  - price: DECIMAL
  - available: BOOLEAN
}

class Booking {
  - id: BIGINT
  - property_id: BIGINT
  - tenant_id: BIGINT
  - check_in: DATE
  - check_out: DATE
  - total_price: DECIMAL
  - status: ENUM
}

class Payment {
  - id: BIGINT
  - booking_id: BIGINT
  - amount: DECIMAL
  - status: ENUM
}

' Связи между таблицами
User ||--o{ Property : владеет
User ||--o{ Booking : бронирует
Property ||--o{ Booking : забронировано
Booking ||--|| Payment : оплачивается

@enduml