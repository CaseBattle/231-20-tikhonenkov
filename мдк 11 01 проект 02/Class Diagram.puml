@startuml
title База данных аренды жилья

' ========================
' СУЩНОСТИ
' ========================

class Role {
  + id: INTEGER
  + name: TEXT
}

class User {
  + id: INTEGER
  + email: TEXT
  + password: TEXT
  + role_id: INTEGER
}

class Property {
  + id: INTEGER
  + landlord_id: INTEGER
  + title: TEXT
  + price: REAL
}

class Booking {
  + id: INTEGER
  + property_id: INTEGER
  + tenant_id: INTEGER
  + status: TEXT
}

class Payment {
  + id: INTEGER
  + booking_id: INTEGER
  + amount: REAL
  + status: TEXT
}

' ========================
' СВЯЗИ
' ========================

Role ||--o{ User : имеет

User ||--o{ Property : владеет
User ||--o{ Booking : бронирует

Property ||--o{ Booking : забронирован

Booking ||--o{ Payment : оплачивается

@enduml